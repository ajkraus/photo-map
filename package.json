{
  "name": "photomap",
  "version": "1.0.0",
  "description": "A desktop application for viewing and organizing photos on an interactive map using EXIF metadata.",
  "main": "src/main/main.js",
  "author": "AJ Kraus",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajkraus/photo-map"
  },
  "keywords": [
    "photos",
    "map",
    "exif",
    "gps",
    "electron",
    "geolocation"
  ],
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "@maptiler/leaflet-maptilersdk": "^4.0.2",
    "dotenv": "^17.3.1",
    "exifr": "^7.1.3",
    "heic-convert": "^2.1.0",
    "image-thumbnail": "^1.0.17",
    "leaflet": "^1.9.4",
    "sqlite3": "^5.1.7"
  },
  "build": {
    "files": [
      "assets/**/*",
      "src/**/*",
      "database/**/*",
      "node_modules/**/*",
      "package.json"
